  "copySlots": [
    "headline",
    "subheadline",
    "continueLabel",
    "chip1",
    "chip2",
    "chip3",
    "resultTitle",
    "resultBody",
    "benefit1",
    "benefit2",
    "benefit3",
    "ctaHeadline",
    "ctaSubhead",
    "ctaLabel"
  ],
  "trackingEvents": ["playable_start", "choice_selected", "demo_completed", "cta_click"]
}
