{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scenario.schema.json",
  "type": "object",
  "required": ["id", "entryScreen", "screens"],
  "properties": {
    "id": { "type": "string" },
    "entryScreen": { "type": "string" },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "elements"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "durationMs": { "type": "number" },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "text": { "type": "string" },
                "textKey": { "type": "string" },
                "hidden": { "type": "boolean" }
              }
            }
          },
          "steps": { "type": "array" },
          "autoNext": { "type": "object" },
          "clickNext": { "type": "object" }
        }
      }
    }
  }
}
